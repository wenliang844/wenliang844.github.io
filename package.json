{
  "name": "wenliang-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CWLBlog 静态站点构建脚本：从 src/posts/*.md 生成文章页、列表页、sitemap 与 RSS。",
  "engines": {
    "node": "20 || >=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:assistant": "node --test tests/assistant.test.mjs tests/assistant-enter.test.mjs tests/assistant-tools-page.test.mjs",
    "test:toolbox": "node --test tests/assistant.test.mjs tests/assistant-enter.test.mjs tests/assistant-tools-page.test.mjs tests/tools.test.mjs",
    "test:tools": "node --test tests/tools.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-branches=70 --test-coverage-functions=85 tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "lint": "eslint js/*.js --fix",
    "lint:check": "eslint js/*.js",
    "check:readonly": "npm run lint:check && npm test && npm run validate:posts",
    "serve": "npx --yes http-server . -p 8137 -c-1",
    "dev": "npm run build && npm run serve",
    "validate": "npm run lint && npm test && npm run validate:posts && npm run build",
    "validate:production": "node scripts/validate-production.mjs",
    "validate:posts": "node scripts/validate-posts.mjs",
    "precommit": "npm run validate"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "yaml": "^2.9.0"
  }
}
