{
  "name": "wenliang-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CWLBlog 静态站点构建脚本：从 src/posts/*.md 生成文章页、列表页、sitemap 与 RSS。",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.mjs",
    "serve": "npx --yes http-server . -p 8137 -c-1",
    "dev": "npm run build && npm run serve"
  },
  "devDependencies": {
    "jsdom": "^27.0.1",
    "marked": "^18.0.5",
    "yaml": "^2.9.0"
  }
}
