{
  "name": "wenliang-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CWLBlog 静态站点构建脚本：从 src/posts/*.md 生成文章页、列表页、sitemap 与 RSS。",
  "engines": {
    "node": "20 || >=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:assistant": "node --test tests/assistant.test.mjs tests/assistant-enter.test.mjs tests/assistant-tools-page.test.mjs",
    "test:toolbox": "node --test tests/assistant.test.mjs tests/assistant-enter.test.mjs tests/assistant-tools-page.test.mjs tests/tools.test.mjs",
    "test:tools": "node --test tests/tools.test.mjs",
    "test:browser-smoke": "npx --yes --package=playwright node scripts/browser-smoke.mjs",
    "test:browser-smoke:full": "npx --yes --package=playwright node scripts/browser-smoke.mjs --scope full",
    "test:pwa-smoke": "npx --yes --package=playwright node scripts/pwa-smoke.mjs",
    "test:http-smoke": "node scripts/http-smoke.mjs",
    "test:http-smoke:full": "node scripts/http-smoke.mjs --scope full",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-branches=70 --test-coverage-functions=85 tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "quality:baseline": "node scripts/write-quality-baseline.mjs",
    "quality:baseline:clean": "node scripts/write-quality-baseline.mjs --require-clean",
    "check:quality-baseline": "node scripts/check-quality-baseline.mjs",
    "generate:service-worker": "node scripts/generate-service-worker.mjs",
    "check:service-worker": "node scripts/generate-service-worker.mjs --check",
    "lint": "eslint js/*.js --fix",
    "lint:check": "eslint js/*.js",
    "check:vendor": "node scripts/check-vendor-manifest.mjs",
    "check:generated": "node scripts/check-generated-drift.mjs && node scripts/check-generated-artifact-manifest.mjs",
    "check:i18n": "node scripts/check-i18n-coverage.mjs",
    "check:seo-feed": "node scripts/check-seo-feed.mjs",
    "check:pwa-precache": "node scripts/check-pwa-precache.mjs",
    "check:suggestions-index": "node scripts/check-suggestions-index.mjs",
    "generate:suggestions-index": "node scripts/check-suggestions-index.mjs --write",
    "seo:report": "node scripts/check-seo-feed.mjs --out",
    "check:readonly": "npm run lint:check && npm test && npm run validate:posts && npm run check:vendor && npm run check:generated && npm run check:i18n && npm run check:seo-feed && npm run check:service-worker && npm run check:pwa-precache && npm run check:suggestions-index && npm run check:quality-baseline",
    "serve": "npx --yes http-server . -p 8137 -c-1",
    "dev": "npm run build && npm run serve",
    "validate": "npm run lint && npm test && npm run validate:posts && npm run build",
    "validate:production": "node scripts/validate-production.mjs",
    "validate:posts": "node scripts/validate-posts.mjs",
    "precommit": "npm run validate"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jsdom": "^27.0.1",
    "marked": "^18.0.5",
    "yaml": "^2.9.0"
  }
}
